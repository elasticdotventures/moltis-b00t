---
import "../styles/global.css"

interface Props {
  title: string
  description?: string
}

const { title, description = "Documentation for Moltis, a secure persistent personal agent server." } = Astro.props
---

<!doctype html>
<html lang="en" data-theme="light" data-theme-choice="auto">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f7f5" />
    <title>{title}</title>
    <script is:inline>
      const storedTheme = localStorage.getItem('moltis-docs-theme') || 'auto'
      const media = window.matchMedia('(prefers-color-scheme: dark)')
      const resolvedTheme = storedTheme === 'auto' ? (media.matches ? 'dark' : 'light') : storedTheme
      document.documentElement.dataset.theme = resolvedTheme
      document.documentElement.dataset.themeChoice = storedTheme
      document.querySelector('meta[name="theme-color"]')?.setAttribute('content', resolvedTheme === 'dark' ? '#111214' : '#f7f7f5')
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Inter:opsz,wght@14..32,400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
  </body>
</html>
